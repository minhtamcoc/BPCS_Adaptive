# goals.config
#
# DOC: Task 1 computes min_alpha_prime, max_alpha_prime, and final_threshold.
cw1 = is_true : _threshold_report
# DOC: Task 2 splits the message into blocks and records conjugation decisions.
cw2 = is_true : _message_blocks
# DOC: Task 3 embeds with adaptive BPCS and writes adaptive_position.json.
cw3 = is_true : _adaptive_position
# DOC: Task 4 extracts frames from adaptive_output.avi.
cw4 = is_true : _adaptive_frames
# DOC: Task 5 decodes and recovers the adaptive BPCS secret.
cw5 = is_true : _adaptive_decoded
